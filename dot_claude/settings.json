{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Skill(*)"
    ],
    "deny": [
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(python -m pip *)",
      "Bash(python3 -m pip *)",
      "Bash(rm *)",
      "Bash(unlink *)",
      "Bash(find *-delete*)",
      "Bash(sudo *)",
      "Bash(doas *)",
      "Read(/home/vincent/.ssh/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vincent/.claude/hooks/jj-workflow-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vincent/.claude/hooks/pre-push-checks.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vincent/.claude/hooks/git-block.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vincent/.claude/hooks/open-plan-viewer.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vincent/.claude/hooks/jj-commit-lint.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vincent/.claude/hooks/task-complete-checks.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vincent/.claude/hooks/session-init.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/vincent/.local/bin/ccstatusline",
    "padding": 3
  },
  "plansDirectory": "./.claude/plans",
  "enabledPlugins": {
    "claudit@quickstop": true,
    "playground@claude-plugins-official": true
  },
  "cleanupPeriodDays": 30
}
