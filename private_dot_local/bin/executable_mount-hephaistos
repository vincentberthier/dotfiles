#!/usr/bin/env bash
# Mount hephaistos:/home/vincent at ~/hephaistos via sshfs.
# For file transfers and drag-and-drop — not for editing code.
#
# Called directly by the user, and also backgrounded from ssh-wake-proxy
# after a cold wake. Must silently no-op (exit 0) if already mounted or if
# sshfs isn't installed, so the wake hook is always safe to fire.

set -euo pipefail

readonly HOST="hephaistos"
readonly REMOTE="/home/vincent"
readonly LOCAL="$HOME/hephaistos"

if ! command -v sshfs >/dev/null 2>&1; then
    [[ -t 1 ]] && echo "sshfs not installed"
    exit 0
fi

if mountpoint -q "$LOCAL"; then
    [[ -t 1 ]] && echo "$LOCAL is already mounted"
    exit 0
fi

mkdir -p "$LOCAL"

#
# Mount options rationale:
# - No `reconnect`. With reconnect, sshfs retries forever on connection
#   loss, keeping the mount alive as a zombie — every subsequent statfs
#   on the mount point (e.g. fastfetch enumerating /proc/mounts) blocks
#   indefinitely. Without it, sshfs exits on connection loss and
#   auto_unmount tears the mount down. The wake-hook in ssh-wake-proxy
#   handles re-mounting on the next ssh invocation.
# - `auto_unmount`: when sshfs dies, FUSE automatically unmounts so no
#   zombie mount remains.
# - Tight ServerAlive*: detect dead remote in ~10s (2 × 5s).
#
sshfs "${HOST}:${REMOTE}" "$LOCAL" \
    -o ServerAliveInterval=5 \
    -o ServerAliveCountMax=2 \
    -o auto_unmount \
    -o idmap=user \
    -o follow_symlinks \
    -o cache=yes

echo "$LOCAL mounted from ${HOST}:${REMOTE}"
