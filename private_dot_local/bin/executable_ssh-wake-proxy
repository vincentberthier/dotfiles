#!/usr/bin/env bash
# SSH ProxyCommand that wakes hephaistos via WoL if asleep, then tunnels
# the connection over nc. Used by `Host hephaistos` in ~/.ssh/config.
#
# Arguments: %h %p (host, port) supplied by ssh.

set -euo pipefail

readonly HOST="$1"
readonly PORT="$2"
readonly MAC="fc:4c:ea:25:6a:96"
readonly WAKE_TIMEOUT=60

port_open() {
    ncat -z -w1 "$HOST" "$PORT" >/dev/null 2>&1
}

cold_wake=false

if ! port_open; then
    cold_wake=true
    wakeonlan "$MAC" >/dev/null
    waited=0
    until port_open; do
        if ((waited >= WAKE_TIMEOUT)); then
            echo "ssh-wake-proxy: $HOST did not come up within ${WAKE_TIMEOUT}s" >&2
            exit 1
        fi
        sleep 1
        waited=$((waited + 1))
    done
fi

# After a cold wake, fire mount-hephaistos in a fully detached subshell so
# the sshfs mount comes up alongside the first ssh session. Idempotent and
# silently no-ops if sshfs is missing or the mount is already live.
# Output is redirected to /dev/null because this script's stdout is piped
# into ssh — any stray bytes would corrupt the SSH banner exchange.
if $cold_wake && [[ -x "$HOME/.local/bin/mount-hephaistos" ]]; then
    ("$HOME/.local/bin/mount-hephaistos" </dev/null >/dev/null 2>&1 &)
fi

exec ncat "$HOST" "$PORT"
