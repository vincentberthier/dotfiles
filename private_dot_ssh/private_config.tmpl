Include ~/.ssh/config.d/*

Host *
	IdentitiesOnly yes
	ServerAliveInterval 60
	Compression yes
	ForwardAgent yes
	StrictHostKeyChecking accept-new
	Port 22

Host gaius
	HostName 192.168.1.2
	User RBFocus
	IdentityFile ~/.ssh/vincent

Host github.com github
	Hostname github.com
	User git
	IdentityFile ~/.ssh/vincent

{{ if eq .chezmoi.hostname "gaia" -}}
Host hephaistos
  HostName 192.168.1.12
  User vincent
  IdentityFile ~/.ssh/vincent
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m
  ProxyCommand ~/.local/bin/ssh-wake-proxy %h %p
{{- else -}}
Host hephaistos
  HostName 192.168.1.12
  User vincent
  IdentityFile ~/.ssh/vincent
{{- end }}

{{ if eq .chezmoi.hostname "hephaistos" -}}
Host gaia
  HostName 192.168.1.11
  User vincent
  IdentityFile ~/.ssh/vincent
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m
{{- end }}
